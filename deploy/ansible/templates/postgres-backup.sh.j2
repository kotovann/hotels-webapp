#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR={{ postgres_backup_dir | quote }}
STORAGE_DAYS={{ postgres_backup_storage_days | quote }}
DB_NAME={{ postgres_db | quote }}
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_NAME="${DB_NAME}-${TIMESTAMP}.dump"

mkdir -p "$BACKUP_DIR"

docker run --rm \
  --network host \
  -e PGPASSWORD={{ postgres_password | quote }} \
  -v "${BACKUP_DIR}:/backups" \
  {{ postgres_backup_image | quote }} \
  pg_dump \
    -h {{ postgres_host | quote }} \
    -p {{ postgres_port | quote }} \
    -U {{ postgres_user | quote }} \
    -d "$DB_NAME" \
    -Fc \
    -f "/backups/$BACKUP_NAME"

find "$BACKUP_DIR" -type f -name "${DB_NAME}-*.dump" -mtime +"$STORAGE_DAYS" -delete
